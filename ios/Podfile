platform :ios, '15.5'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# Before CocoaPods resolves dependencies I redirect the google_mlkit symlinks
# to local pod overrides that compile on the simulator via #if !TARGET_OS_SIMULATOR.
# The upstream google_mlkit pods link against MLKit pre-built device-only frameworks
# that have no simulator slice, so without this the sim build fails at link time.
pre_install do |installer|
  symlink_dir = File.join(__dir__, '.symlinks', 'plugins')
  local_pods_dir = File.join(__dir__, 'LocalPods')
  ['google_mlkit_pose_detection', 'google_mlkit_commons'].each do |plugin|
    symlink_path = File.join(symlink_dir, plugin)
    local_pod_path = File.join(local_pods_dir, plugin)
    if File.exist?(local_pod_path) && (File.symlink?(symlink_path) || File.exist?(symlink_path))
      File.delete(symlink_path)
      File.symlink(local_pod_path, symlink_path)
      puts "Redirected #{plugin} symlink to local simulator-compatible pod"
    end
  end
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  # These pre-built MLKit frameworks ship only arm64-iOS-device slices.
  # I need to exclude them from the linker flags when building for the simulator.
  device_only_frameworks = %w[
    MLImage MLKitCommon MLKitPoseDetection MLKitPoseDetectionAccurate
    MLKitPoseDetectionCommon MLKitVision MLKitXenoCommon GoogleMLKit
  ]

  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Resource bundle targets (privacy manifests etc.) must not be signed --
      # signing them causes "requires a development team" errors on device builds.
      if target.respond_to?(:product_type) && target.product_type == 'com.apple.product-type.bundle'
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'NO'
      else
        config.build_settings['CODE_SIGNING_ALLOWED'] = 'YES'
        config.build_settings['CODE_SIGNING_REQUIRED'] = 'YES'
      end
      # Allow arm64 simulator builds -- the local MLKit pod overrides handle
      # this via #if guards so I can safely clear the exclusion here.
      config.build_settings['EXCLUDED_ARCHS[sdk=iphonesimulator*]'] = ''
    end
  end

  # Generate Flutter/SimulatorExclusions.xcconfig so the Runner linker
  # does not pull in the device-only MLKit frameworks for simulator builds.
  # I pull OTHER_LDFLAGS and FRAMEWORK_SEARCH_PATHS from the debug pods xcconfig
  # and emit [sdk=iphonesimulator*] variants with the MLKit entries stripped out.
  # I deliberately do NOT include $(inherited) in the conditional values because
  # inheriting from the unconditional pods xcconfig would re-introduce MLKit.
  debug_xcconfig_path = "#{installer.sandbox.root}/Target Support Files/Pods-Runner/Pods-Runner.debug.xcconfig"
  if File.exist?(debug_xcconfig_path)
    content = File.read(debug_xcconfig_path)

    ldflags_line = content.lines.find { |l| l.start_with?('OTHER_LDFLAGS') }
    sim_ldflags = nil
    if ldflags_line
      sim_ldflags = ldflags_line.chomp
        .sub('OTHER_LDFLAGS =', 'OTHER_LDFLAGS[sdk=iphonesimulator*] =')
        .gsub('$(inherited)', '')
      device_only_frameworks.each { |fw| sim_ldflags = sim_ldflags.gsub(/-framework "#{fw}"\s*/, '') }
      sim_ldflags = sim_ldflags.gsub(/\s+/, ' ').strip
    end

    fwpath_line = content.lines.find { |l| l.start_with?('FRAMEWORK_SEARCH_PATHS') }
    sim_fwpaths = nil
    if fwpath_line
      sim_fwpaths = fwpath_line.chomp
        .sub('FRAMEWORK_SEARCH_PATHS =', 'FRAMEWORK_SEARCH_PATHS[sdk=iphonesimulator*] =')
        .gsub('$(inherited)', '')
      device_only_frameworks.each do |fw|
        sim_fwpaths = sim_fwpaths.gsub(/"[^"]*#{Regexp.escape(fw)}[^"]*"\s*/, '')
      end
      sim_fwpaths = sim_fwpaths.gsub(/\s+/, ' ').strip
      # Make sure PODS_CONFIGURATION_BUILD_DIR is in the path so Pods_Runner.framework is found
      unless sim_fwpaths.include?('"$(PODS_CONFIGURATION_BUILD_DIR)"')
        sim_fwpaths += ' "$(PODS_CONFIGURATION_BUILD_DIR)"'
      end
    end

    ios_dir = File.expand_path('..', installer.sandbox.root)
    xcconfig_content = "// Auto-generated -- do not edit. See Podfile post_install.\n"
    xcconfig_content += "// Strips device-only MLKit frameworks for simulator builds.\n\n"
    xcconfig_content += "#{sim_ldflags}\n" if sim_ldflags
    xcconfig_content += "#{sim_fwpaths}\n" if sim_fwpaths
    File.write(File.join(ios_dir, 'Flutter', 'SimulatorExclusions.xcconfig'), xcconfig_content)
    puts "Generated Flutter/SimulatorExclusions.xcconfig"
  end
end
